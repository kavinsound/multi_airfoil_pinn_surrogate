import json
import math
import os
from dataclasses import dataclass, asdict
import numpy as np
from scipy.stats import qmc


@dataclass
class AirfoilConfig:
    n_airfoils: int
    Re: float
    alpha_global: float
    chords: list
    deflections: list
    gaps: list
    polar_angles: list
    radial_ratios: list


class SobolAirfoilGenerator:
    def __init__(self, state_file="airfoil_state.json", dim=10):
        self.state_file = state_file
        self.dim = dim

        # Sobol sequence (deterministic low-discrepancy)
        self.sampler = qmc.Sobol(d=dim, scramble=False)

        self.index = 0
        self._load_state()

    def _load_state(self):
        if os.path.exists(self.state_file):
            with open(self.state_file, "r") as f:
                state = json.load(f)
                self.index = state.get("index", 0)
        else:
            self.index = 0

    def _save_state(self):
        with open(self.state_file, "w") as f:
            json.dump({"index": self.index}, f, indent=4)

    def _next_sobol(self):
        # advance Sobol sequence
        sample = self.sampler.random_base2(m=int(math.log2(self.index + 2)))
        self.index += 1
        self._save_state()
        return sample[-1]  # latest point

    # mapping functions
    def _log_scale_Re(self, u):
        # 1e4 to 1e7 typical aero range
        return 10 ** (4 + u * 3)

    def _random_airfoil_count(self, u):
        return 1 + int(u * 3)  # 1–3

    def generate(self):
        u = self._next_sobol()

        # map Sobol vector
        n_airfoils = self._random_airfoil_count(u[0])

        Re = self._log_scale_Re(u[1])
        alpha_global = -10 + 20 * u[2]  # -10 to +10 degrees

        chords = []
        deflections = []
        gaps = []
        polar_angles = []
        radial_ratios = []

        # first airfoil is reference
        chords.append(1.0)
        deflections.append((u[3] - 0.5) * 10)
        polar_angles.append(u[4] * 2 * math.pi)
        radial_ratios.append(1.0)

        for i in range(1, n_airfoils):
            chords.append(0.3 + 0.7 * u[(5 + i) % len(u)])
            deflections.append((u[(6 + i) % len(u)] - 0.5) * 15)

            gaps.append(0.05 + 0.3 * u[(7 + i) % len(u)])

            polar_angles.append(u[(8 + i) % len(u)] * 2 * math.pi)

            # radial decay from main foil
            radial_ratios.append(0.3 + 0.7 * u[(9 + i) % len(u)])

        cfg = AirfoilConfig(
            n_airfoils=n_airfoils,
            Re=Re,
            alpha_global=alpha_global,
            chords=chords,
            deflections=deflections,
            gaps=gaps,
            polar_angles=polar_angles,
            radial_ratios=radial_ratios
        )

        return cfg

    def save_config(self, cfg: AirfoilConfig, filename="airfoil_config.json"):
        with open(filename, "w") as f:
            json.dump(asdict(cfg), f, indent=4)
