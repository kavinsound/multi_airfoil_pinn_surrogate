FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{
    // For the 4-equation Langtry-Menter model:
    //RASModel        kOmegaSSTLM; 
    
    // OR for the 3-equation model:
    RASModel        kOmegaSSTGamma;

    turbulence      on;
    printCoeffs     on;
}

