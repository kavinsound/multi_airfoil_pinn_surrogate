FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      gamma;
}

dimensions      [0 0 0 0 0 0 0];
internalField   uniform 1;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1;
    }
    outlet
    {
        type            zeroGradient;
    }
    airfoil // your airfoil/body geometry
    {
        type            zeroGradient; // or fixedValue uniform 1; depending on OpenFOAM version
    }
    

    front
    {
        type            empty;
    }
    back
    {
        type            empty;
    }
}