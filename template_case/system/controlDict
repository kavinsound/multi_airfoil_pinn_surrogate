FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         10000;

deltaT          1;
// steady-state does not use adjustTimeStep or Courant numbers
// adjustTimeStep no; 

writeControl    runTime;
writeInterval   500; // Write every 500 iterations to save disk space

purgeWrite      2;   // Keeps only the latest 2 write folders
writeFormat     binary;
writePrecision  6;

runTimeModifiable yes;
functions
{
    #include "forceCoeffs"
    #include "fieldAverage"
}


