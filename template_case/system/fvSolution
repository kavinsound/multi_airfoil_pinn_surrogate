FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver           GAMG;
        smoother         GaussSeidel;
        tolerance        1e-6;
        relTol           0.01;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-05;
        relTol          0.1;
    }

    UFinal
    {
        $U;
        relTol          0;
    }


    "(U|k|omega|gamma)"
    {
        solver          PBiCGStMVM;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.1; // Allows quick inner loop steps
    }

    "(U|k|omega|gamma)Final"
    {
        solver          PBiCGStMVM;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0;   // Force absolute convergence on the final PIMPLE loop
    }

}

PIMPLE
{
    momentumPredictor   yes; 
    nOuterCorrectors    3;
    nCorrectors         3;
    nNonOrthogonalCorrectors 0;
}


relaxationFactors
{
    equations
    {
        U               0.7;
        "k.*"          0.7;
        "omega.*"      0.7;
        "gamma.*"      0.7;
    }


}

cache
{
    grad(U);
}


